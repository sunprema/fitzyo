{
  "mcpServers": {
    "live-agent": {
      "type": "http",
      "url": "http://localhost:4000/live_agent/mcp"
    },
    "ash_ai": {
      "type": "http",
      "url": "http://localhost:4000/ash_ai/mcp"
    },
    "svelte": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@sveltejs/mcp"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    }
  }
}